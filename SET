void display(int *p,int n)
{
    int i;
    printf("\n{");
    for(i=0;i<n;i++)
    {
        printf(" %d ",p[i]);
    }
    printf("}");
}






int u(int p[],int q[],int x,int y,int union_array[])
{
  int i,j,k=0;
     for(i=0;i<x;i++)
   {
          union_array[k]=p[i];
          k++;
       }
   for(i=0;i<y;i++)
   {
       
      for(j=0;j<k;j++)
      {
         if(union_array[j]==q[i])
           break;
      }
     if(j==k)
     {
       union_array[k]=q[i];
       k++;
     }
   }
    return k;
}





int intersection(int p[],int q[],int x,int y,int intersection_array[])
    {
      int z=0;
       for(int i=0;i<x;i++)
    {
        for(int j=0;j<y;j++)
        {
            if(p[i]==q[j])
            {
                intersection_array[z]=p[i];
                z++;
                
            }
            
        }
        
    }
    return z;
    }




int difference(int p[],int q[],int x,int y,int difference_array[])
 {
    int i=0,j=0,k=0;
    while(i<x)
    {
       j=0;
       while(j<y)
    {
      if(p[i]==q[j])
      {
        break;
      }
      j++;
    }
    if(j==y)
    {
      difference_array[k]=p[i];
      k++;
    }
    i++;

  }
  return k;
}
    



int sy_difference(int p[],int q[],int x,int y,int sy_array[])
{
  int i,j,l,k=0,m=0,n=0,c[max],d[max];
  for( i=0;i<x;i++)
    {
        for(j=0;j<y;j++)
        {
            if(q[j]==p[i])
             break;
        }
        if(j==y)
        {
            
            for(l=0;l<k;l++)
            {
                if(c[l]==p[i])
                 break;
            }
            if(l==k)
            {
                c[k]=p[i];
                k++;
            }
        }
        
    }
    for( i=0;i<y;i++)
    {
        for(j=0;j<x;j++)
        {
            if(q[i]==p[j])
             break;
        }
        if(j==x)
        { 
            for(l=0;l<m;l++)
            {
                if(d[l]==q[i])
                 break;
            }
            if(l==m)
            {
                d[m]=q[i];
                m++;
            }
        }
        
    }
    
    for(i=0;i<k;i++)
    {
        sy_array[n]=c[i];
        n++;
    }
    for(i=0;i<m;i++)
    {
        sy_array[n]=d[i];
        n++;
    }
    return n;
}

